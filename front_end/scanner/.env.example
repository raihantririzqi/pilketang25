# Backend API URL
BACKEND_URL=http://localhost:3001

# Secret key untuk validasi komunikasi scanner ↔ backend (harus sama dengan backend SCANNER_SECRET)
SCANNER_SECRET="your-scanner-secret-key"

# Token untuk unlock kiosk via URL: https://scanner.domain.site/?access_key=<KIOSK_ACCESS_TOKEN>
KIOSK_ACCESS_TOKEN="your-kiosk-access-token"
